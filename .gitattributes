# Ignore CMake files
CMakeLists.txt linguist-vendored
*.cmake linguist-vendored

# Ignore platform-specific folders (Flutter)
android/** linguist-vendored
ios/** linguist-vendored
linux/** linguist-vendored
windows/** linguist-vendored
macos/** linguist-vendored
build/** linguist-vendored

# Ignore native / compiled files
*.cpp linguist-vendored
*.h linguist-vendored
*.so linguist-vendored
*.dll linguist-vendored

# Ignore model files
*.pb linguist-vendored
*.tflite linguist-vendored
*.onnx linguist-vendored
*.bin linguist-vendored
*.data linguist-vendored

# Ensure Dart is counted
*.dart linguist-detectable=true
